# ============================================
# MapLeads CRM - Environment Configuration
# ============================================
# This file contains all environment variables for the application.
# NEVER commit this file to version control.
# Copy this file to .env.production for production deployment.
# ============================================

# Server Configuration
# ====================
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# =====================
MONGODB_URI=mongodb://localhost:27017/mapleads-crm
# Alternative production URI:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mapleads-crm?retryWrites=true&w=majority

# JWT Authentication
# ==================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Application Configuration
# =========================
APP_NAME=MapLeads CRM
API_VERSION=v1

# CORS Configuration (Optional)
# =============================
# CLIENT_URL=http://localhost:3000
# For development, leave empty to allow all origins (handled in server.js)

# File Upload Configuration (Optional)
# ====================================
# MAX_FILE_SIZE=5MB
# UPLOAD_PATH=./uploads

# Email Configuration (Optional)
# ==============================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@mapleads.com

# Logging Configuration (Optional)
# ================================
# LOG_LEVEL=info
# LOG_FILE=./logs/app.log